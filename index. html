.form-control{width:100%;padding:10px 14px;background:#111820;border:1px solid #1e2d3d;border-radius:10px;color:#fff;font-size:14px;box-sizing:border-box;outline:none;transition:border-color 0.2s;font-family:'Space Grotesk',sans-serif;}
.form-control:focus{border-color:#00e5ff;}
.risk-selector{display:flex;gap:8px;}
.risk-btn{flex:1;padding:9px;background:#111820;border:1px solid #1e2d3d;border-radius:10px;color:#889;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;font-family:'Space Grotesk',sans-serif;}
.risk-btn.active{background:rgba(0,229,255,0.1);border-color:#00e5ff;color:#00e5ff;}
.deploy-confirm-btn{width:100%;padding:14px;background:linear-gradient(135deg,#00e5ff,#0077ff);border:none;border-radius:12px;color:#000;font-size:15px;font-weight:800;cursor:pointer;transition:all 0.2s;box-shadow:0 0 24px rgba(0,229,255,0.3);margin-top:4px;font-family:'Space Grotesk',sans-serif;}
.deploy-confirm-btn:hover{transform:translateY(-1px);box-shadow:0 0 36px rgba(0,229,255,0.5);}

