.r1{width:130px;height:130px;border-color:rgba(0,229,255,0.15);animation-duration:8s;}
.r2{width:95px;height:95px;border-color:rgba(0,255,135,0.2);animation-duration:5s;animation-direction:reverse;}
.r3{width:62px;height:62px;border-color:rgba(180,100,255,0.25);animation-duration:3s;}
.bot-orb-core{font-size:34px;position:relative;z-index:2;filter:drop-shadow(0 0 12px rgba(0,229,255,0.5));animation:floatCore 3s ease-in-out infinite;}
.bot-filter-bar{display:flex;align-items:center;gap:8px;margin-bottom:20px;flex-wrap:wrap;}
.bfb{padding:8px 16px;border-radius:8px;border:1px solid #1e2d3d;background:#0d1117;color:#889;font-size:13px;cursor:pointer;transition:all 0.2s;font-weight:600;}
.bfb:hover{border-color:#00e5ff;color:#00e5ff;background:rgba(0,229,255,0.05);}
.bfb.active{border-color:#00e5ff;color:#00e5ff;background:rgba(0,229,255,0.1);}
.deploy-btn{background:linear-gradient(135deg,#00e5ff,#0077ff) !important;color:#000 !important;font-weight:800 !important;border:none !important;box-shadow:0 0 18px rgba(0,229,255,0.3);}
.deploy-btn:hover{transform:translateY(-1px);box-shadow:0 0 28px rgba(0,229,255,0.5);}
.bot-card-wrap{background:#0d1117;border:1px solid #1e2d3d;border-radius:16px;padding:22px;transition:all 0.3s;position:relative;overflow:hidden;cursor:pointer;}
.bot-card-wrap::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:16px 16px 0 0;background:var(--bot-accent,#00e5ff);opacity:0.7;}
.bot-card-wrap:hover{transform:translateY(-3px);box-shadow:0 8px 30px rgba(0,0,0,0.4);}
.bot-status-badge{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:1px;display:flex;align-items:center;gap:5px;}
.bot-status-badge.running{background:rgba(0,255,135,0.12);color:#00ff87;border:1px solid rgba(0,255,135,0.25);}
.bot-status-badge.paused{background:rgba(255,149,0,0.12);color:#ff9500;border:1px solid rgba(255,149,0,0.25);}
.bot-status-badge.stopped{background:rgba(255,61,90,0.12);color:#ff3d5a;border:1px solid rgba(255,61,90,0.25);}
.status-dot{width:6px;height:6px;border-radius:50%;background:currentColor;}
.running .status-dot{animation:blinkDot 1.2s infinite;}
.bot-spark{display:flex;align-items:flex-end;gap:2px;height:28px;margin-bottom:14px;}
.spark-bar{flex:1;border-radius:2px 2px 0 0;transition:height 0.4s ease;min-height:2px;}
.spark-bar.pos{background:rgba(0,255,135,0.5);}
.spark-bar.neg{background:rgba(255,61,90,0.5);}
.live-badge{font-size:11px;font-weight:700;color:#00ff87;letter-spacing:1.5px;padding:3px 8px;background:rgba(0,255,135,0.1);border:1px solid rgba(0,255,135,0.2);border-radius:20px;margin-left:10px;animation:pulseBadge 2s infinite;}
.active-bot-row{display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:12px;border:1px solid #1e2d3d;background:#0a0e14;margin-bottom:10px;transition:border-color 0.2s;}
.active-bot-row:hover{border-color:#2a3d55;}
.abr-bar-fill{height:100%;border-radius:6px;position:relative;overflow:hidden;}
.abr-bar-fill::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);animation:shimmer 2s infinite;}

/* MODAL */
.modal-overlay{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal-box{background:#0d1117;border:1px solid #1e2d3d;border-radius:20px;width:100%;max-width:420px;overflow:hidden;animation:modalIn 0.25s cubic-bezier(0.34,1.56,0.64,1);}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid #1e2d3d;font-size:17px;font-weight:800;color:#fff;}
.modal-close{background:none;border:none;color:#667;cursor:pointer;font-size:16px;width:28px;height:28px;border-radius:6px;transition:all 0.2s;}
