  document.getElementById('stkSuccess').style.display='block';
  document.getElementById('stkReceipt').textContent=`M-Pesa Ref: ${receipt} | +$${(amt+bonus).toFixed(2)} credited!`;
  const btn=document.getElementById('depSubmitBtn');
  if(btn){btn.disabled=false;btn.textContent='✅ Submit Deposit';}
  updateDash();
  addNotification('Deposit Confirmed 💰',`$${amt} via M-Pesa. Ref: ${receipt}${bonus>0?' + $'+bonus+' bonus!':''}`);
  showToast(`🎉 M-Pesa payment confirmed!\n$${amt}${bonus>0?' + $'+bonus+' bonus':''} credited!\nRef: ${receipt}`);
}
function processCreditDeposit(amt, method) {
  const prog=document.getElementById('depProg');
