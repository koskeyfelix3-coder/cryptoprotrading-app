function closePosition(id) {
  const t=_openPositions.find(x=>x.id===id); if(!t) return;
  t.status='closed';
  t.exitPrice=prices[t.pair]?.p||t.entryPrice;
  if(acct==='demo') demoBalance+=t.amount+t.pnl;
  else realBalance+=t.amount+t.pnl;
  if(acct==='demo') demoProfit+=t.pnl;
  else realProfit+=t.pnl;
  inTrades=Math.max(0,inTrades-t.amount);
  _openPositions=_openPositions.filter(x=>x.id!==id);
  tradeHistory.unshift(t);
  renderOpenPositions();
  renderRecentMini();
  updateTradeAvail();
  updateDash();
  showToast(`Position closed. PnL: ${t.pnl>=0?'+':''}$${t.pnl.toFixed(2)}`);
}
