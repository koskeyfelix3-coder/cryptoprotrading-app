  const el = document.getElementById(containerId); if (!el) return;
  if (tvWidgets[containerId]) { tvWidgets[containerId] = null; }
  el.innerHTML = '';
  try {
    tvWidgets[containerId] = new TradingView.widget({
      autosize: true,
      symbol: 'BINANCE:' + symbol,
      interval: '60',
      timezone: 'Etc/UTC',
      theme: 'dark',
      style: '1',
      locale: 'en',
      toolbar_bg: '#0D1421',
      enable_publishing: false,
      allow_symbol_change: true,
      container_id: containerId,
      hide_side_toolbar: false,
      studies: ['RSI@tv-basicstudies','MACD@tv-basicstudies'],
      overrides: {
        'paneProperties.background': '#0D1421',
        'paneProperties.vertGridProperties.color': '#1E2D42',
        'paneProperties.horzGridProperties.color': '#1E2D42',
        'symbolWatermarkProperties.transparency': 90,
        'scalesProperties.textColor': '#6B7A99',
      }
