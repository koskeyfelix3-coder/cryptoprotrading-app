.notif-dd{position:absolute;top:50px;right:0;background:var(--bg3);border:1px solid var(--bdr);border-radius:14px;width:320px;max-height:min(420px,70vh);overflow-y:auto;z-index:9999;display:none;box-shadow:0 20px 60px rgba(0,0,0,.6)}
