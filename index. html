.bot-hero-content p{color:#8899aa;font-size:15px;margin:0 0 20px;max-width:420px;line-height:1.6;}
.bot-hero-stats{display:flex;align-items:center;gap:20px;}
.bhs{display:flex;flex-direction:column;}
.bhs-val{font-size:22px;font-weight:800;color:#fff;}
.bhs-val.green-txt{color:#00ff87;}
.bhs-label{font-size:11px;color:#667;text-transform:uppercase;letter-spacing:1px;margin-top:2px;}
.bhs-div{width:1px;height:36px;background:#1e2d3d;}
.bot-orb{width:130px;height:130px;position:relative;display:flex;align-items:center;justify-content:center;}
