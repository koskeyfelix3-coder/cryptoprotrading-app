.iv-active{background:var(--green) !important;color:#000 !important;}
.chart-tool-btn{padding:6px 10px;border:1px solid var(--bdr);border-radius:7px;background:var(--bg3);color:var(--t2);font-size:12px;font-weight:700;cursor:pointer;font-family:'Space Grotesk',sans-serif;transition:all .2s;}
