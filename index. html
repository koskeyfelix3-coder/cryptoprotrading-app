function go(layerId) {
  document.querySelectorAll('.layer').forEach(l => l.classList.remove('active'));
  const el = document.getElementById(layerId);
  if (!el) return;
  el.classList.add('active');
  window.scrollTo(0, 0);
  const aiBtn = document.getElementById('aiBtn');
  const authLayers = ['L_dash','L_trade','L_bots','L_history','L_withdraw','L_referral','L_profile','L_deposit','L_signals'];
  if (aiBtn) aiBtn.style.display = authLayers.includes(layerId) ? 'block' : 'none';
  if (layerId === 'L_charts')   { setTimeout(() => initTV('tv_chart_main', chartPair), 300); }
  if (layerId === 'L_dash')     { updateDash(); updateQuickStats(); updateSentiment(); setTimeout(() => initTV('tv_chart_dash','BTCUSDT'), 300); }
