function processMpesaDeposit(amt) {
  const phone=document.getElementById('mpesaPhone')?.value.trim();
  if(!phone){showToast('Enter your M-Pesa phone number.',true);return;}
  const pending=document.getElementById('stkPending');
  const success=document.getElementById('stkSuccess');
  const error=document.getElementById('stkError');
  const prog=document.getElementById('depProg');
  if(pending) pending.style.display='block';
  if(success) success.style.display='none';
  if(error) error.style.display='none';
  if(prog) prog.classList.add('show');
  const btn=document.getElementById('depSubmitBtn');
  if(btn){btn.disabled=true;btn.textContent='⏳ Waiting for M-Pesa...';}
  let timer=60;
  mpesaTimerInt=setInterval(()=>{
    timer--;
    const tEl=document.getElementById('stkTimer');if(tEl) tEl.textContent=timer;
    const fill=document.getElementById('depProgFill');
    const txt=document.getElementById('depProgTxt');
    const pct=Math.round((60-timer)/60*70);
    if(fill) fill.style.width=pct+'%';
    if(txt) txt.textContent=pct+'% — Waiting for confirmation…';
    if(timer<=0) clearInterval(mpesaTimerInt);
  },1000);
  setTimeout(()=>{
    clearInterval(mpesaTimerInt);
    if(pending) pending.style.display='none';
    const fill=document.getElementById('depProgFill');
    const txt=document.getElementById('depProgTxt');
    const lbl=document.getElementById('depProgLbl');
    const progAnim=()=>{
      let p=70;
      const iv=setInterval(()=>{
        p=Math.min(100,p+5);
        if(fill) fill.style.width=p+'%';
        if(txt) txt.textContent=p+'% — Crediting account…';
        if(p>=100){clearInterval(iv);
          if(lbl) lbl.textContent='✅ Payment Confirmed!';
          finalizeMpesaDeposit(amt,phone);
        }
      },150);
    };
    progAnim();
  },12000+Math.random()*6000);
}
