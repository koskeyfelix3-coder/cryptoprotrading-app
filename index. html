    name:strategy+' Bot',
    strategy,pair,
    status:'running',
    roi:'+0.0%',
    trades:0,
    profit:'+$0',
    accent:'#00e5ff',
    desc:`Automated ${strategy} on ${pair}`,
    allocation:amount,
    risk,
    icon:'🤖'
  };
  botTemplates.unshift(newBot);
  if(acct==='demo') demoBalance-=amount; else realBalance-=amount;
  closeDeployModal();
  renderBotCards();
  renderActiveBots();
  renderBotStats();
  updateBotHeroStats();
  updateDash();
  showToast(`🤖 ${strategy} bot deployed on ${pair}!\nAllocation: $${amount}`);
  addNotification('Bot Deployed 🤖',`${strategy} running on ${pair}`);
}

// ============================================================
// PRICE ALERTS
// ============================================================
function addAlert() {
  const sym=document.getElementById('alertSym')?.value;
  const dir=document.getElementById('alertDir')?.value;
  const price=parseFloat(document.getElementById('alertPrice')?.value);
  if(!sym||!dir||!price){showToast('Fill all alert fields.',true);return;}
  priceAlerts.push({id:Date.now(),sym,dir,price,active:true});
  renderActiveAlerts();
  showToast(`🔔 Alert set: ${sym} ${dir} $${price.toLocaleString()}`);
  if(document.getElementById('alertPrice')) document.getElementById('alertPrice').value='';
}
function renderActiveAlerts() {
  const el=document.getElementById('activeAlerts'); if(!el) return;
  if(!priceAlerts.length){el.innerHTML=`<div style="text-align:center;padding:20px;color:var(--t2);font-size:13px;">No alerts set. Create one above.</div>`;return;}
  el.innerHTML=priceAlerts.map(a=>`
    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--bg3);border:1px solid var(--bdr);border-radius:10px;margin-bottom:8px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-size:18px;">${a.dir==='above'?'📈':'📉'}</span>
        <div><div style="font-size:13px;font-weight:700;">${a.sym}/USDT ${a.dir} $${a.price.toLocaleString()}</div><div style="font-size:11px;color:var(--t2);">${a.active?'Active':'Triggered'}</div></div>
      </div>
      <button onclick="removeAlert(${a.id})" style="padding:5px 12px;background:var(--rdim);border:1px solid rgba(246,70,93,.3);border-radius:7px;color:var(--red);font-size:12px;font-weight:700;cursor:pointer;font-family:'Space Grotesk',sans-serif;">Remove</button>
    </div>`).join('');
}
function removeAlert(id) {
  priceAlerts=priceAlerts.filter(a=>a.id!==id);
  renderActiveAlerts();
}
function checkPriceAlerts(price, sym) {
  priceAlerts.forEach(a=>{
    if(!a.active||a.sym!==sym) return;
    if((a.dir==='above'&&price>=a.price)||(a.dir==='below'&&price<=a.price)){
      a.active=false;
      showToast(`🔔 Alert! ${sym} is ${a.dir} $${a.price.toLocaleString()}`);
      addNotification('Price Alert 🔔',`${sym} hit $${price.toFixed(2)}`);
    }
  });
}

// ============================================================
// NOTIFICATIONS
// ============================================================
function addNotification(title, desc) {
  notifications.unshift({title,desc,time:new Date().toLocaleTimeString(),read:false});
  const count=notifications.filter(n=>!n.read).length;
  const el=document.getElementById('notifCount');
  if(el){el.textContent=count;el.style.display=count>0?'flex':'none';}
  renderNotifications();
}
function renderNotifications() {
  const el=document.getElementById('notifList'); if(!el) return;
  if(!notifications.length){el.innerHTML=`<div style="padding:20px;text-align:center;color:var(--t2);font-size:13px;">No notifications yet.</div>`;return;}
  el.innerHTML=notifications.slice(0,8).map(n=>`
    <div class="notif-item">
      <div class="notif-item-title">${n.title}</div>
      <div class="notif-item-desc">${n.desc}</div>
      <div class="notif-item-time">${n.time}</div>
    </div>`).join('');
}
function toggleNotif() {
  const dd=document.getElementById('notifDD');
  dd.classList.toggle('open');
  if(dd.classList.contains('open')) renderNotifications();
}
function clearNotif() {
  notifications.forEach(n=>n.read=true);
  const el=document.getElementById('notifCount');
  if(el){el.textContent='0';el.style.display='none';}
}
document.addEventListener('click',e=>{
  const wrapper=document.getElementById('notifWrapper');
  if(wrapper&&!wrapper.contains(e.target)) document.getElementById('notifDD')?.classList.remove('open');
  if(!document.getElementById('aiPanel')?.contains(e.target)&&!document.getElementById('aiBtn')?.contains(e.target)) document.getElementById('aiPanel')?.classList.remove('open');
});

