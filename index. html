function drawEquityCurve() {
  const canvas=document.getElementById('equityCanvas'); if(!canvas||!tradeHistory.length) return;
  const ctx=canvas.getContext('2d');
  canvas.width=canvas.offsetWidth||600;canvas.height=110;
  const vals=[];let running=demoBalance;
  [...tradeHistory].reverse().forEach(t=>{running+=t.pnl;vals.push(running);});
  if(!vals.length) return;
  const min=Math.min(...vals),max=Math.max(...vals),range=Math.max(max-min,1);
  const w=canvas.width,h=canvas.height,pad=10;
  ctx.clearRect(0,0,w,h);
  const grad=ctx.createLinearGradient(0,pad,0,h-pad);
  grad.addColorStop(0,'rgba(14,203,129,0.3)');grad.addColorStop(1,'rgba(14,203,129,0)');
  ctx.beginPath();
  vals.forEach((v,i)=>{
    const x=pad+(i/(vals.length-1))*(w-pad*2);
    const y=h-pad-((v-min)/range)*(h-pad*2);
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  });
  ctx.strokeStyle='#0ECB81';ctx.lineWidth=2;ctx.stroke();
  const lastX=pad+((vals.length-1)/(vals.length-1))*(w-pad*2);
  ctx.lineTo(lastX,h-pad);ctx.lineTo(pad,h-pad);ctx.fillStyle=grad;ctx.fill();
}

