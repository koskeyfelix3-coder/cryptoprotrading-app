function executeTrade() {
  const amt=parseFloat(document.getElementById('tradeAmt')?.value)||0;
  const lev=parseInt(document.getElementById('tradeLeverage')?.value)||10;
  if(!user){showToast('⚠️ Please login to trade.',true);go('L_login');return;}
  if(amt<10){showToast('⚠️ Minimum trade amount is $10.',true);return;}
  const bal=acct==='demo'?demoBalance:realBalance;
  if(amt>bal){showToast('⚠️ Insufficient balance.',true);return;}
  const price=prices[tradePair]?.p||98000;
  const posSize=amt*lev;
  const liq=_tradeType==='buy'?price*(1-1/lev*0.9):price*(1+1/lev*0.9);
  const tp=parseFloat(document.getElementById('tradeTP')?.value)||null;
  const sl=parseFloat(document.getElementById('tradeSL')?.value)||null;
  const trade={
    id:'T'+Date.now(),
    pair:tradePair,
    type:_tradeType,
    orderType:_orderType,
    amount:amt,
    leverage:lev,
    posSize,
    entryPrice:price,
    currentPrice:price,
    pnl:0,
    liqPrice:liq,
    tp,sl,
    time:new Date().toISOString(),
    status:'open'
  };
  if(acct==='demo') demoBalance=Math.max(0, demoBalance-amt);
  else realBalance=Math.max(0, realBalance-amt);
  inTrades+=amt;
  _openPositions.push(trade);
  updateTradeAvail();
  document.getElementById('tradeAmt').value='';
  updateTradeSummary();
  renderOpenPositions();
  showToast(`✅ ${_tradeType.toUpperCase()} ${(tradePair.replace('USDT','/USDT'))} opened!\nSize: $${posSize.toLocaleString()} | Leverage: ${lev}x\nEntry: $${price.toLocaleString(undefined,{maximumFractionDigits:2})}`);
  addNotification('Trade Opened',`${_tradeType.toUpperCase()} ${tradePair.replace('USDT','/USDT')} at $${price.toFixed(2)}`);
  simulateTradeClose(trade);
}
function simulateTradeClose(trade) {
  const delay = 8000 + Math.random()*15000;
  setTimeout(()=>{
    const exitPrice=prices[tradePair]?.p||trade.entryPrice;
    const priceDiff=exitPrice-trade.entryPrice;
    const pnl=trade.type==='buy'?
      (priceDiff/trade.entryPrice)*trade.posSize:
      (-priceDiff/trade.entryPrice)*trade.posSize;
    const finalPnl = pnl * (Math.random()>0.35 ? 1 : -1) * (0.5 + Math.random());
    const cappedPnl = Math.max(-trade.amount*0.8, Math.min(trade.amount*3, finalPnl));
    trade.status='closed';
    trade.pnl=cappedPnl;
    trade.exitPrice=exitPrice;
    trade.closeTime=new Date().toISOString();
    if(acct==='demo') demoBalance+=trade.amount+cappedPnl;
    else realBalance+=trade.amount+cappedPnl;
    if(acct==='demo') demoProfit+=cappedPnl;
    else realProfit+=cappedPnl;
    inTrades=Math.max(0,inTrades-trade.amount);
    _openPositions=_openPositions.filter(t=>t.id!==trade.id);
    tradeHistory.unshift(trade);
    renderOpenPositions();
    renderRecentMini();
    updateTradeAvail();
    updateDash();
    const pnlStr=(cappedPnl>=0?'+':'')+cappedPnl.toFixed(2);
    showToast(`${cappedPnl>=0?'🎉 Profit':'📉 Loss'}: ${pnlStr} | ${trade.pair.replace('USDT','/USDT')} ${trade.type.toUpperCase()} closed`);
    addNotification(cappedPnl>=0?'Trade Win 🎉':'Trade Loss',`${trade.pair.replace('USDT','/USDT')}: ${pnlStr}`);
  }, delay);
}
