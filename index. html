  } catch(e) {
    el.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;height:100%;background:var(--bg2);border-radius:10px;color:var(--t2);font-size:14px;flex-direction:column;gap:10px;"><div style="font-size:32px;">📈</div><div>TradingView chart loading…</div></div>`;
