function updatePrices() {
  Object.keys(prices).forEach(sym => {
    const v = prices[sym];
    const change = (Math.random()-0.485) * v.p * 0.0008;
    v.p = Math.max(0.001, v.p + change);
    v.high = Math.max(v.high, v.p);
    v.low = Math.min(v.low, v.p);
  });
  // Update dashboard prices
  const btcEl=document.getElementById('dashBTC'),ethEl=document.getElementById('dashETH'),solEl=document.getElementById('dashSOL');
  if(btcEl) btcEl.textContent='$'+prices.BTCUSDT.p.toLocaleString(undefined,{maximumFractionDigits:0});
  if(ethEl) ethEl.textContent='$'+prices.ETHUSDT.p.toLocaleString(undefined,{maximumFractionDigits:0});
  if(solEl) solEl.textContent='$'+prices.SOLUSDT.p.toLocaleString(undefined,{maximumFractionDigits:2});
  // Update chart page
  const cpEl=document.getElementById('chartPrice');
  if(cpEl && document.getElementById('L_charts')?.classList.contains('active')) {
    const v=prices[chartPair];
    cpEl.textContent='$'+v.p.toLocaleString(undefined,{maximumFractionDigits:2});
    const chEl=document.getElementById('chartChange');
    if(chEl){chEl.textContent=(v.ch>=0?'+':'')+v.ch.toFixed(2)+'%';chEl.className='';chEl.style.cssText=`font-size:13px;font-weight:700;padding:5px 12px;border-radius:8px;font-family:'JetBrains Mono',monospace;background:${v.ch>=0?'var(--gdim)':'var(--rdim)'};color:${v.ch>=0?'var(--green)':'var(--red)'}`;}}
  // Update trade page
  const tpEl=document.getElementById('tradePrice');
  if(tpEl && document.getElementById('L_trade')?.classList.contains('active')) {
    const v=prices[tradePair];
    const old=parseFloat(tpEl.textContent.replace(/[$,]/g,''));
    tpEl.textContent='$'+v.p.toLocaleString(undefined,{maximumFractionDigits:2});
    tpEl.classList.remove('fu','fd');
    void tpEl.offsetWidth;
    tpEl.classList.add(v.p>=old?'fu':'fd');
    document.getElementById('tEntryDisplay').textContent='$'+v.p.toLocaleString(undefined,{maximumFractionDigits:2});
    document.getElementById('tradeMidPrice').textContent='$'+v.p.toLocaleString(undefined,{maximumFractionDigits:2});
    renderTradeOrderBook(v.p);
    renderTradeRecentFeed(v.p);
    checkPriceAlerts(v.p, tradePair.replace('USDT',''));
  }
  // Update open positions PnL
  updateOpenPositionsPnL();
}

