function renderHistory() {
  const container=document.getElementById('histContainer'); if(!container) return;
  const statsGrid=document.getElementById('histStatsGrid');
  const wins=tradeHistory.filter(t=>t.pnl>0);
  const losses=tradeHistory.filter(t=>t.pnl<=0);
  const totalProfit=tradeHistory.reduce((s,t)=>s+t.pnl,0);
  const best=wins.length?Math.max(...wins.map(t=>t.pnl)):0;
  const worst=losses.length?Math.min(...losses.map(t=>t.pnl)):0;
  if(statsGrid) statsGrid.innerHTML=`
    <div class="stat-card"><div class="stat-icon">📊</div><div class="stat-val">${tradeHistory.length}</div><div class="stat-lbl">Total Trades</div></div>
    <div class="stat-card"><div class="stat-icon">✅</div><div class="stat-val">${wins.length}</div><div class="stat-lbl">Winning Trades</div></div>
    <div class="stat-card"><div class="stat-icon">📉</div><div class="stat-val">${losses.length}</div><div class="stat-lbl">Losing Trades</div></div>
    <div class="stat-card"><div class="stat-icon">💰</div><div class="stat-val" style="color:${totalProfit>=0?'var(--green)':'var(--red)'}">${totalProfit>=0?'+':''}$${Math.abs(totalProfit).toFixed(2)}</div><div class="stat-lbl">Net PnL</div></div>
  `;
  const bestEl=document.getElementById('bestTrade'),worstEl=document.getElementById('worstTrade');
  const avgWinEl=document.getElementById('avgWin'),avgLossEl=document.getElementById('avgLoss');
  if(bestEl) bestEl.textContent='+$'+best.toFixed(2);
