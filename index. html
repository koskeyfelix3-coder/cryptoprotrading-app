const aiResponses = {
  'deposit': 'To deposit funds: Go to Dashboard → Deposit. We accept M-Pesa (instant STK Push), Crypto (USDT/BTC/ETH), and Bank Transfer. Minimum deposit is $10. First deposit gets 100% bonus! 🎉',
  'withdraw': 'Withdrawals are processed within 5–30 minutes! Go to Dashboard → Withdraw. Minimum $50. Methods: M-Pesa, Bank, or Crypto. Fee: 2%.',
  'bot': 'Our AI bots run 24/7! Best for beginners: DCA Bot (low risk) or Grid Master Pro. Recommended allocation: $200–$500. Average ROI: 15–31% monthly! 🤖',
  'btc': `BTC is currently at $${prices.BTCUSDT.p.toLocaleString(undefined,{maximumFractionDigits:0})}. Our AI signals show a ${Math.random()>0.4?'BULLISH 📈':'NEUTRAL ⚖️'} outlook. Key resistance at $100,000. Consider a LONG position with 10x leverage. Always use stop-loss!`,
  'profit': 'Our top traders are earning $500–$5,000+ daily! Use AI bots for passive income, follow our signals for manual trades. Start with our DEMO account to practice risk-free.',
  'signal': 'Latest signals: BTC/USDT → STRONG BUY (92% confidence), ETH/USDT → BUY (87%), SOL/USDT → SELL (78%). Updated every 60 seconds by our ML engine.',
  'default': "Great question! 🚀 I'm here to help you maximize your profits. You can ask me about trading strategies, deposits, withdrawals, bots, or market analysis. What would you like to know?",
};
function getAIResponse(msg) {
  const lower=msg.toLowerCase();
  if(lower.includes('deposit')||lower.includes('fund')) return aiResponses.deposit;
  if(lower.includes('withdraw')||lower.includes('cash')) return aiResponses.withdraw;
  if(lower.includes('bot')||lower.includes('automat')) return aiResponses.bot;
  if(lower.includes('btc')||lower.includes('bitcoin')||lower.includes('price')) return aiResponses.btc;
  if(lower.includes('profit')||lower.includes('earn')||lower.includes('money')) return aiResponses.profit;
  if(lower.includes('signal')||lower.includes('trade')) return aiResponses.signal;
  return aiResponses.default;
}
function sendAI() {
  const input=document.getElementById('aiInput');
  if(!input||!input.value.trim()) return;
  sendAIQuick(input.value.trim());
  input.value='';
}
function sendAIQuick(msg) {
  const msgs=document.getElementById('aiMsgs'); if(!msgs) return;
  const userDiv=document.createElement('div');
  userDiv.className='ai-msg user';
  userDiv.textContent=msg;
  msgs.appendChild(userDiv);
  const typing=document.createElement('div');
  typing.className='ai-typing';
  typing.innerHTML='<span></span><span></span><span></span>';
  msgs.appendChild(typing);
  msgs.scrollTop=msgs.scrollHeight;
  setTimeout(()=>{
    typing.remove();
    const botDiv=document.createElement('div');
    botDiv.className='ai-msg bot';
    botDiv.innerHTML=getAIResponse(msg);
    msgs.appendChild(botDiv);
    msgs.scrollTop=msgs.scrollHeight;
  },900+Math.random()*600);
}

