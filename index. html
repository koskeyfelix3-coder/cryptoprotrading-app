  const txt=document.getElementById('depProgTxt');
  const lbl=document.getElementById('depProgLbl');
  const btn=document.getElementById('depSubmitBtn');
  if(btn){btn.disabled=true;btn.textContent='⏳ Processing...';}
  let p=0;
  const iv=setInterval(()=>{
    p=Math.min(100,p+(5+Math.random()*8));
    if(fill) fill.style.width=p+'%';
    if(txt) txt.textContent=Math.round(p)+'% — Verifying payment…';
    if(p>=100){
      clearInterval(iv);
      if(lbl) lbl.textContent='✅ Payment Verified!';
